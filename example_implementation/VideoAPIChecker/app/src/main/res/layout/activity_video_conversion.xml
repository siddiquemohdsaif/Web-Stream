<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/videoConversionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".conversion.VideoConversionActivity">

    <TextView
        android:id="@+id/videoConversionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Video Conversion"
        android:textAppearance="?attr/textAppearanceHeadlineMedium" />

    <TextView
        android:id="@+id/videoConversionSourceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Latest video from Downloads/WebStreamVideo will be used."
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <Button
        android:id="@+id/convertJpegButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Convert in JPEG" />

    <Button
        android:id="@+id/convertJxlButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Convert in JXL" />

    <TextView
        android:id="@+id/videoConversionStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Converted images and report will be saved in Downloads."
        android:textAppearance="?attr/textAppearanceBodySmall" />

</LinearLayout>
