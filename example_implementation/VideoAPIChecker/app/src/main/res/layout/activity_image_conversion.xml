<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/imageConversionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".conversion.ImageConversionActivity">

    <TextView
        android:id="@+id/imageConversionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Image Conversion"
        android:textAppearance="?attr/textAppearanceHeadlineMedium" />

    <TextView
        android:id="@+id/imageConversionSourceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Images from Download/WebStreamPhoto will be used."
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <Button
        android:id="@+id/convertImageJpegButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Convert in JPEG" />

    <Button
        android:id="@+id/convertImageJxlButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Convert in JXL" />

    <TextView
        android:id="@+id/imageConversionStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Converted images and report will be saved in Download."
        android:textAppearance="?attr/textAppearanceBodySmall" />

</LinearLayout>
