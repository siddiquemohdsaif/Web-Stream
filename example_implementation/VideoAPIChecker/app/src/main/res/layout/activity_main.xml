<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Video API Checker"
        android:textAppearance="?attr/textAppearanceHeadlineMedium" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Choose a provider to test."
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <Button
        android:id="@+id/openAgoraButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Open Agora" />

    <Button
        android:id="@+id/openHundredMsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open 100ms" />

    <Button
        android:id="@+id/openGetStreamButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open GetStream" />

    <Button
        android:id="@+id/openVideoSdkButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open VideoSDK" />

    <Button
        android:id="@+id/openWebStreamButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Open webStream" />

    <Button
        android:id="@+id/downloadApkButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Download APK" />

    <Button
        android:id="@+id/convertVideoButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Convert Video in Image" />

    <Button
        android:id="@+id/convertImageButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Convert Image into Image" />

    <Button
        android:id="@+id/jpegBitmapJxlButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="JPEG Bitmap to JXL" />

    <TextView
        android:id="@+id/downloadStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Download report will be saved in Downloads."
        android:textAppearance="?attr/textAppearanceBodySmall" />

</LinearLayout>
