<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/videoSdkRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050606"
    android:keepScreenOn="true"
    tools:context=".videosdk.VideoSdkActivity">

    <FrameLayout
        android:id="@+id/remoteVideoSdkVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#050606">

        <live.videosdk.rtc.android.VideoView
            android:id="@+id/remoteVideoSdkVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/remoteVideoSdkPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="32dp"
            android:text="Waiting for remote video"
            android:textColor="#D7FFFFFF"
            android:textSize="18sp" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_call_top_scrim" />

    <View
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_call_bottom_scrim" />

    <LinearLayout
        android:id="@+id/videoSdkSetupPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_call_setup_panel"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VideoSDK video call"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/videoSdkTokenInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#66FFFFFF"
            android:hint="API key"
            android:inputType="text"
            android:singleLine="true"
            android:text="a061c774-b826-45d3-91fd-5dee05ec1250"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <EditText
            android:id="@+id/videoSdkSecretInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#66FFFFFF"
            android:hint="API secret"
            android:inputType="textPassword"
            android:singleLine="true"
            android:text="e14ae562c96eaffc9726c6f6b274a9be9ad9b658662d996cabd61d12865721e8"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <EditText
            android:id="@+id/videoSdkMeetingIdInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#66FFFFFF"
            android:hint="Meeting ID (blank creates new)"
            android:inputType="text"
            android:singleLine="true"
            android:text="2ju7-d8c5-csnk"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <EditText
            android:id="@+id/videoSdkNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#66FFFFFF"
            android:hint="Display name"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:text="Android User"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#B3FFFFFF" />

        <Button
            android:id="@+id/videoSdkJoinButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#25D366"
            android:text="Start video call"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoSdkCallHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="158dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VideoSDK"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/videoSdkStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Idle"
            android:textColor="#D9FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/videoSdkCallDurationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Connected: 0 sec"
            android:textColor="#D9FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/localVideoSdkVideoContainer"
        android:layout_width="118dp"
        android:layout_height="168dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="92dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_local_video_frame"
        android:elevation="12dp"
        android:padding="2dp">

        <live.videosdk.rtc.android.VideoView
            android:id="@+id/localVideoSdkVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/localVideoSdkPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="You"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/videoSdkCallControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp"
        android:visibility="gone">

        <Button
            android:id="@+id/videoSdkMuteButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:backgroundTint="#2B3431"
            android:enabled="false"
            android:text="Mute"
            android:textColor="#FFFFFFFF" />

        <Button
            android:id="@+id/videoSdkSwitchCameraButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:backgroundTint="#2B3431"
            android:enabled="false"
            android:text="Flip"
            android:textColor="#FFFFFFFF" />

        <Button
            android:id="@+id/videoSdkLeaveButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:backgroundTint="#E53935"
            android:enabled="false"
            android:text="End"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
