<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/jpegBitmapJxlRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".conversion.JpegBitmapJxlActivity">

    <TextView
        android:id="@+id/jpegBitmapJxlTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="JPEG Bitmap to JXL"
        android:textAppearance="?attr/textAppearanceHeadlineMedium" />

    <TextView
        android:id="@+id/jpegBitmapJxlSourceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="JPEG images from Download/WebStreamPhoto will be used."
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <Button
        android:id="@+id/convertJpegBitmapJxlButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Convert JPEG Bitmap to JXL" />

    <TextView
        android:id="@+id/jpegBitmapJxlStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="JXL images and report will be saved in Download."
        android:textAppearance="?attr/textAppearanceBodySmall" />

</LinearLayout>
